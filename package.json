{
  "name": "opencode-triage",
  "version": "1.2.3",
  "description": "Deterministic skill router for OpenCode — saves ~94% tokens by hiding skills from the system prompt and routing via keyword matching",
  "license": "MIT",
  "author": "OpenCode Community",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "skills",
    "triage",
    "router",
    "skill-discovery",
    "token-optimization",
    "ai-coding-agent"
  ],
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "opencode-triage": "./bin/opencode-triage.cjs"
  },
  "files": [
    "src/",
    "bin/",
    ".opencode/commands/",
    "postinstall.cjs",
    "README.md"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "node --experimental-strip-types --test test/**/*.test.ts",
    "prepublishOnly": "npm run check && npm run test",
    "postinstall": "node postinstall.cjs"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.0"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": false
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cascharly/opencode-triage"
  },
  "bugs": {
    "url": "https://github.com/cascharly/opencode-triage/issues"
  },
  "homepage": "https://github.com/cascharly/opencode-triage#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "typescript": "6.0.3"
  }
}
