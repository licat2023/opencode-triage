  "description": "Deterministic skill router for OpenCode — saves ~94% tokens by hiding skills from the system prompt and routing via keyword matching",
  "license": "MIT",
  "author": "OpenCode Community",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "skills",
    "triage",
    "router",
    "skill-discovery",
    "token-optimization",
    "ai-coding-agent"
  ],
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "opencode-triage": "./cli.js"
  },
  "files": [
    "src/",
    "cli.js",
    "README.md"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "prepublishOnly": "echo 'Ready to publish'"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.0"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": false
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cascharly/opencode-triage"
  },
  "bugs": {
    "url": "https://github.com/cascharly/opencode-triage/issues"
  },
  "homepage": "https://github.com/cascharly/opencode-triage#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
